# 687333G
from fractions import Fraction
l = int(input())
print(l)
pigs: list[list[int]] = []
pigs.append([0, 100, 0])
for i in range(l):
    a, b, c = [int(a) for a in input().split(" ")]
    # print(a, b, c)
    pigs.append([a, b, c])
print(pigs)
prefixsum: list[float] = [0] * (l+1)
for i in range(1, l+1):
    attempts: float = 100 / pigs[i][1]
    if(i == 1):
        prefix = 0
        loop_sum = pigs[i][0]
        print(prefix, loop_sum, attempts)
        prefixsum[i] = prefix + loop_sum * attempts
        continue
    prefix = prefixsum[pigs[i][2]-1]
    loop_sum = prefixsum[i-1] - prefixsum[pigs[i][2]-1] + pigs[i][0]
    print(prefixsum)
    print(prefix, loop_sum, attempts, pigs[i])
    prefixsum[i] = prefix + loop_sum * attempts
print(prefixsum)

